      },
      {
        "name": "policy_loss",
        "direction": "down",
        "importance": 1
      },
      {
        "name": "value_loss",
        "direction": "down",
        "importance": 1
      },
      {
        "name": "entropy",
        "direction": "stable_or_down",
        "importance": 1
      },
      {
        "name": "success_rate",
        "direction": "up",
        "importance": 1
      }
    ],
    "eval_early_stop_rules": [
      {
        "name": "nan_or_inf",
        "condition": "logs contain nan/inf",
        "action": "early_stop"
      },
      {
        "name": "divergence",
        "condition": "loss diverges or explodes",
        "action": "early_stop"
      },
      {
        "name": "stagnation",
        "condition": "metrics stall far below expectation for multiple checks",
        "action": "early_stop"
      }
    ],
